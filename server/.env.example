# NivaasHMS server environment
# Copy this file to server/.env and fill in the values.
# Never commit real credentials.

# Runtime
# Local default is 3000. Production platforms usually inject this.
PORT=3000

# MongoDB Atlas
# From MongoDB Atlas -> Database -> Connect -> Drivers.
# The app appends /hotel-booking in server/configs/db.js, so do not add a
# database name at the end of this URI.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net

# Clerk
# From Clerk Dashboard -> Configure -> API keys.
# @clerk/express uses these values for server-side auth middleware.
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# From Clerk Dashboard -> Configure -> Webhooks -> your endpoint.
# The endpoint is POST /api/clerk.
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# Stripe
# From Stripe Dashboard -> Developers -> API keys.
# The current server code reads STRIPE_SECRET_KEY for Checkout and webhooks.
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# From Stripe CLI during local testing, or Stripe Dashboard -> Developers ->
# Webhooks for a deployed endpoint. The endpoint is POST /api/stripe.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# Cloudinary
# From Cloudinary Console -> Dashboard.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=xxxxxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Brevo SMTP
# From Brevo -> SMTP & API -> SMTP. Host/port are hardcoded in
# server/configs/nodemailer.js as smtp-relay.brevo.com:587.
SMTP_USER=your-smtp-login@example.com
SMTP_PASS=xxxxxxxxxxxxxxxxxxxxxxxx

# Booking confirmation email sender.
# Use a verified sender/domain in Brevo.
SENDER_EMAIL=no-reply@example.com

# Display symbol used in booking confirmation emails.
# Defaults to "$" in server/controllers/bookingController.js when unset.
CURRENCY=$
