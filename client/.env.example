# NivaasHMS client environment
# Copy this file to client/.env.local and fill in the values.
# Vite only exposes variables prefixed with VITE_ to browser code.

# Backend API base URL. Do not include a trailing slash.
# Local dev: http://localhost:3000
VITE_BACKEND_URL=http://localhost:3000

# From Clerk Dashboard -> Configure -> API keys.
# Same publishable key as CLERK_PUBLISHABLE_KEY on the server.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Currency symbol shown in the UI.
# Defaults to "$" in client/src/context/AppContext.jsx when unset.
VITE_CURRENCY=$
